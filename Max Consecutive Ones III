class Solution {
    public int longestOnes(int[] nums, int k) {
        int maxans = 0;
        int n = nums.length;
        for(int i = 0;i<n;i++){
            int count = 0;
            for(int j = i;j<n;j++){
                if(nums[j] == 0){
                    count++;
                }
                if(count > k){
                    break;
                }
                maxans = Math.max(maxans,j - i +1);
        }
        }
        return maxans;
    }
}

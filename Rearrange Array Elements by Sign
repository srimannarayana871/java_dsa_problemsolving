class Solution {
    public int[] rearrangeArray(int[] nums) {
        int n = nums.length;
        int[] ans = new int[n];

        int postiveindex = 0;
        int negativeindex = 1;

        for(int num : nums){
            if(num > 0){
                ans[postiveindex] = num;
                postiveindex += 2;
            }
            else{
                ans[negativeindex] = num;
                negativeindex += 2;
            }
        }
        return ans;
    }
}

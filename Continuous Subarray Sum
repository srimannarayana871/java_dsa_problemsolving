class Solution {
    public boolean checkSubarraySum(int[] nums, int k) {
        HashMap<Integer,Integer> map = new HashMap<>();
        map.put(0,-1);
        int n = nums.length;
        int prefixsum = 0;
        for(int i = 0;i<n;i++){
            prefixsum += nums[i];
            int remain = prefixsum % k;
            if(map.containsKey(remain)){
             if(i - map.get(remain) >= 2){
                return true;
             }
            }
        }
        return false;
    }
}
